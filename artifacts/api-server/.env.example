# ────────────────────────────────────────────────────────────────────────────────
# SwasthyaSaar API Server — Environment Variables
# Copy this file to .env and fill in the values.
# ────────────────────────────────────────────────────────────────────────────────

# Port that the Express server will listen on
PORT=3000

# Set to "production" for prod, "development" for local dev
NODE_ENV=development

# ─── Logging ─────────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5000

# ─── Database (ready for backend teammate) ────────────────────────────────────
# PostgreSQL connection string — uncomment when DB is ready
# DATABASE_URL=postgresql://user:password@localhost:5432/swasthyasaar

# ─── Auth (optional — for production JWT auth) ────────────────────────────────
# JWT_SECRET=your-super-secret-key-here
# JWT_EXPIRES_IN=24h
