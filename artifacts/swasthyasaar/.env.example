# ────────────────────────────────────────────────────────────────────────────────
# SwasthyaSaar Frontend — Environment Variables
# Copy this file to .env and fill in the values.
# ────────────────────────────────────────────────────────────────────────────────

# Port for the local Vite dev server
PORT=5000

# URL prefix — set to '/' for local dev, or '/swasthyasaar' if hosted under a sub-path
BASE_PATH=/

# ─── API Integration ──────────────────────────────────────────────────────────
# Full URL of the backend Express API server
# Leave blank or unset in demo mode — the app will use local mock data
VITE_API_URL=http://localhost:3000

# Set to "false" to switch from mock data to live API calls
# Default: "true" (demo mode)
VITE_USE_MOCK=true
